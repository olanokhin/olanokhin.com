---
import "../styles/global.css";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Alex Anokhin — Founding AI Engineer</title>
  <meta name="description" content="Alex Anokhin — Founding AI Engineer for forward-deployed AI, production RAG, agentic systems, and AI security." />
  <meta name="author" content="Alex Anokhin" />
  <meta name="theme-color" content="#08090b" />
  <meta name="color-scheme" content="dark" />
  <meta name="format-detection" content="telephone=no" />
  <meta name="apple-mobile-web-app-title" content="Alex Anokhin" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="canonical" href="https://olanokhin.com/" />
  <link rel="alternate" type="application/rss+xml" title="Alex Anokhin News RSS" href="https://olanokhin.com/rss.xml" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://olanokhin.com/" />
  <meta property="og:title" content="Alex Anokhin — Founding AI Engineer" />
  <meta property="og:description" content="Forward-deployed AI · Production RAG · Agentic Systems · AI Security." />
  <meta property="og:image" content="https://olanokhin.com/img/social-media-card.jpg" />
  <meta property="og:image:width" content="1536" />
  <meta property="og:image:height" content="1024" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content="https://olanokhin.com/" />
  <meta name="twitter:title" content="Alex Anokhin — Founding AI Engineer" />
  <meta name="twitter:description" content="Forward-deployed AI · Production RAG · Agentic Systems · AI Security." />
  <meta name="twitter:image" content="https://olanokhin.com/img/social-media-card.jpg" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Alex Anokhin",
    url: "https://olanokhin.com/",
    jobTitle: "Founding AI Engineer",
    knowsAbout: [
      "Forward-deployed AI",
      "Production RAG",
      "Agentic systems",
      "AI security"
    ],
    sameAs: [
      "https://github.com/olanokhin",
      "https://www.linkedin.com/in/olanokhin/"
    ]
  })} />
  <link rel="icon" type="image/x-icon" href="/favicon_io/favicon.ico" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon_io/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon_io/favicon-32x32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon_io/apple-touch-icon.png" />
  <link rel="manifest" href="/favicon_io/site.webmanifest" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'JetBrains Mono', monospace;
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: .025; pointer-events: none;
    }

    body::after {
      content: '';
      position: fixed; inset: 0; z-index: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
    }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 0 32px;
      height: 52px;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(8,9,11,.88);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800; font-size: 14px;
      color: #fff; text-decoration: none; letter-spacing: -.01em;
    }
    .nav-logo span { color: var(--accent); }

    .nav-links { display: flex; gap: 28px; list-style: none; }
    .nav-links a {
      font-size: 10px; letter-spacing: .1em; text-transform: uppercase;
      color: var(--muted); text-decoration: none; transition: color .2s;
    }
    .nav-links a:hover { color: var(--accent); }
    .nav-toggle { display: none; }
    .nav-menu-btn {
      display: none; width: 34px; height: 34px; border: 1px solid var(--border);
      border-radius: 6px; align-items: center; justify-content: center; cursor: pointer;
      background: var(--surface);
    }
    .nav-menu-btn span,
    .nav-menu-btn span::before,
    .nav-menu-btn span::after {
      display: block; width: 14px; height: 2px; border-radius: 2px; background: var(--text);
      content: ''; transition: transform .2s, opacity .2s, background .2s;
    }
    .nav-menu-btn span::before { transform: translateY(-5px); }
    .nav-menu-btn span::after { transform: translateY(3px); }

    /* LAYOUT */
    .container {
      position: relative; z-index: 1;
      max-width: 780px; margin: 0 auto;
      padding: 116px 24px 100px;
    }

    section { margin-bottom: 88px; }

    .section-label {
      font-size: 10px; letter-spacing: .18em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 32px;
      display: flex; align-items: center; gap: 10px;
    }
    .section-label::after {
      content: ''; flex: 1; height: 1px; background: var(--border);
    }

    /* HERO */
    .hero { margin-bottom: 80px; animation: fadeUp .7s ease both; }

    .eyebrow {
      font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 16px;
    }

    h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.6rem, 7vw, 4.2rem);
      font-weight: 800; line-height: 1.05;
      letter-spacing: -.02em; color: #fff;
    }
    h1 span { color: var(--accent); }

    .subtitle {
      margin-top: 20px; font-size: 12px;
      color: var(--muted2); line-height: 1.9; max-width: 520px;
    }

    .status {
      display: inline-flex; align-items: center; gap: 8px;
      margin-top: 28px; padding: 6px 14px;
      border: 1px solid var(--border); border-radius: 999px;
      font-size: 11px; color: var(--muted); background: var(--surface);
    }
    .status-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent); box-shadow: 0 0 8px var(--accent);
      animation: pulse 2s ease infinite;
    }

    .hero-cover {
      display: block;
      width: min(100%, 680px);
      height: auto;
      margin-top: 34px;
      border: 1px solid var(--border2);
      border-radius: 8px;
      background: var(--surface);
      box-shadow: 0 24px 80px rgba(0,0,0,.28);
    }

    /* BUTTONS */
    .contact-row {
      display: flex; flex-wrap: wrap; gap: 10px;
      margin-top: 30px; animation: fadeUp .7s .1s ease both;
    }

    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 9px 18px; border: 1px solid var(--border); border-radius: 6px;
      font-family: 'JetBrains Mono', monospace; font-size: 11px;
      color: var(--text); text-decoration: none; background: var(--surface);
      transition: border-color .2s, color .2s, background .2s, transform .15s;
      letter-spacing: .03em;
    }
    .btn:hover {
      border-color: var(--accent); color: var(--accent);
      background: var(--tag-bg); transform: translateY(-2px);
    }
    .btn-primary {
      background: var(--accent2); border-color: var(--accent); color: var(--accent);
    }

    /* METRICS */
    .metrics {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1px; background: var(--border);
      border: 1px solid var(--border); border-radius: 8px; overflow: hidden;
      margin-top: 52px; animation: fadeUp .7s .2s ease both;
    }
    .metric { background: var(--surface); padding: 20px 22px; text-align: center; }
    .metric-num {
      font-family: 'Syne', sans-serif; font-size: 1.9rem; font-weight: 800;
      color: var(--accent); line-height: 1;
    }
    .metric-label { font-size: 10px; color: var(--muted); margin-top: 6px; line-height: 1.5; }

    /* ABOUT */
    .about-text {
      font-size: 13px; line-height: 2; color: var(--muted2);
      animation: fadeUp .7s .15s ease both;
    }
    .about-text p + p { margin-top: 16px; }
    .about-text strong { color: var(--text); font-weight: 500; }
    .about-text em { color: var(--accent); font-style: normal; }

    /* TIMELINE */
    .timeline { animation: fadeUp .7s .2s ease both; }
    .tl-year-group { margin-bottom: 36px; }

    .tl-year {
      font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700;
      color: var(--accent); letter-spacing: .1em;
      margin-bottom: 14px;
      display: flex; align-items: center; gap: 10px;
    }
    .tl-year::after { content: ''; flex: 1; height: 1px; background: var(--accent2); opacity: .4; }

    .tl-item { display: grid; grid-template-columns: 2px 1fr; gap: 0 20px; margin-bottom: 10px; }

    .tl-line {
      width: 2px; background: var(--border2); border-radius: 2px; position: relative;
    }
    .tl-line::before {
      content: ''; position: absolute; top: 7px; left: -3px;
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--surface); border: 1.5px solid var(--accent);
    }

    .tl-card {
      padding: 16px 20px 18px;
      border: 1px solid var(--border); border-radius: 8px; background: var(--surface);
      transition: border-color .2s;
    }
    .tl-card:hover { border-color: rgba(var(--accent-rgb), .2); }

    .tl-header {
      display: flex; justify-content: space-between; align-items: flex-start;
      gap: 12px; margin-bottom: 8px;
    }
    .tl-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; color: #fff; }
    .tl-company { font-size: 11px; color: var(--muted); margin-top: 2px; }

    .tl-tag {
      flex-shrink: 0; font-size: 10px; padding: 3px 9px;
      border-radius: 999px; white-space: nowrap; margin-top: 2px;
      border: 1px solid rgba(var(--accent-rgb), .2); color: var(--accent); background: var(--tag-bg);
    }
    .tl-tag.enterprise { border-color: rgba(100,160,255,.2); color: #64a0ff; background: rgba(100,160,255,.05); }
    .tl-tag.freelance  { border-color: rgba(255,180,50,.2);  color: #ffb432; background: rgba(255,180,50,.05);  }
    .tl-tag.venture    { border-color: rgba(200,100,255,.2); color: #c864ff; background: rgba(200,100,255,.05); }

    .tl-bullets { list-style: none; margin-top: 10px; }
    .tl-bullets li {
      font-size: 11px; color: var(--muted2); line-height: 1.75;
      padding-left: 16px; position: relative;
    }
    .tl-bullets li::before {
      content: '→'; position: absolute; left: 0;
      color: var(--accent); font-size: 10px;
    }
    .tl-bullets li + li { margin-top: 4px; }

    /* RESEARCH */
    .research-grid { display: grid; gap: 12px; animation: fadeUp .7s .2s ease both; }

    .r-card {
      padding: 20px 24px; border: 1px solid var(--border); border-radius: 8px;
      background: var(--surface);
      display: flex; justify-content: space-between; align-items: flex-start; gap: 16px;
      transition: border-color .2s, background .2s; text-decoration: none; color: inherit;
    }
    .r-card:hover { border-color: rgba(var(--accent-rgb), .25); background: rgba(var(--accent-rgb), .03); }

    .r-card-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; color: #fff; margin-bottom: 6px; }
    .r-card-desc { font-size: 11px; color: var(--muted); line-height: 1.75; }

    .r-card-tag {
      flex-shrink: 0; font-size: 10px; padding: 3px 9px; border-radius: 999px;
      border: 1px solid rgba(var(--accent-rgb), .2); color: var(--accent); background: var(--tag-bg);
      white-space: nowrap; margin-top: 2px;
    }

    /* HACKATHONS */
    .hack-list { display: grid; gap: 10px; animation: fadeUp .7s .2s ease both; }

    .hack-item {
      display: flex; align-items: flex-start; gap: 16px;
      padding: 16px 20px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface);
    }
    .hack-medal { font-size: 20px; line-height: 1; flex-shrink: 0; margin-top: 2px; }
    .hack-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 13px; color: #fff; margin-bottom: 4px; }
    .hack-desc { font-size: 11px; color: var(--muted2); line-height: 1.65; }
    .hack-date { font-size: 10px; color: var(--muted); margin-top: 5px; }

    /* OPERATING MODE */
    .mode-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;
      animation: fadeUp .7s .2s ease both;
    }
    .mode-card {
      padding: 18px 20px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface);
    }
    .mode-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 13px; color: #fff; margin-bottom: 8px; }
    .mode-desc { font-size: 11px; color: var(--muted2); line-height: 1.75; }

    /* WRITING */
    .writing-grid { display: grid; gap: 12px; animation: fadeUp .7s .2s ease both; }

    .w-card {
      padding: 18px 22px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface);
      transition: border-color .2s, background .2s;
    }
    .w-card:hover { border-color: rgba(var(--accent-rgb), .2); background: rgba(var(--accent-rgb), .02); }

    .w-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 10px; }
    .w-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 13px; color: #fff; line-height: 1.4; }

    .w-cat {
      flex-shrink: 0; font-size: 10px; padding: 2px 8px;
      border-radius: 4px; border: 1px solid var(--border); color: var(--muted);
    }

    .w-hook {
      font-size: 12px; color: var(--muted2); line-height: 1.75; font-style: italic;
      border-left: 2px solid var(--accent2); padding-left: 12px;
    }
    .w-list {
      list-style: none; border-left: 2px solid var(--accent2); padding-left: 12px;
    }
    .w-list li {
      font-size: 11px; color: var(--muted2); line-height: 1.65; position: relative; padding-left: 14px;
      font-weight: 300;
    }
    .w-list li + li { margin-top: 3px; }
    .w-list li::before {
      content: '→'; position: absolute; left: 0; color: var(--muted); font-size: 9px;
    }

    /* EDUCATION */
    .education-grid { display: grid; gap: 12px; animation: fadeUp .7s .2s ease both; }
    .edu-card {
      padding: 18px 22px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface);
      transition: border-color .2s, background .2s;
    }
    .edu-card:hover { border-color: rgba(var(--accent-rgb), .2); background: rgba(var(--accent-rgb), .02); }
    .edu-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 8px; }
    .edu-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 13px; color: #fff; line-height: 1.4; }
    .edu-date {
      flex-shrink: 0; font-size: 10px; padding: 2px 8px; border-radius: 4px;
      border: 1px solid rgba(var(--accent-rgb), .2); color: var(--accent); background: var(--tag-bg);
    }
    .edu-desc { font-size: 11px; color: var(--muted2); line-height: 1.75; }
    .edu-list { list-style: none; margin-top: 10px; display: grid; gap: 5px; }
    .edu-list li {
      font-size: 11px; color: var(--muted2); line-height: 1.65; position: relative; padding-left: 14px;
    }
    .edu-list li::before {
      content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 9px;
    }
    .edu-list strong { color: var(--text); font-weight: 500; }

    /* STACK */
    .pills { display: flex; flex-wrap: wrap; gap: 8px; animation: fadeUp .7s .2s ease both; }
    .pill {
      font-size: 11px; padding: 5px 12px; border-radius: 4px;
      border: 1px solid var(--border); color: var(--muted); background: var(--surface);
    }

    /* FOOTER */
    footer {
      margin-top: 60px; padding-top: 32px; border-top: 1px solid var(--border);
      font-size: 11px; color: var(--muted);
      display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; } 50% { opacity: .3; }
    }

    @media (max-width: 600px) {
      .metrics { grid-template-columns: 1fr 1fr; }
      .metrics .metric:last-child { grid-column: span 2; }
      nav { padding: 0 18px; }
      .nav-menu-btn { display: flex; }
      .nav-links {
        position: absolute; top: 52px; left: 0; right: 0; display: grid; gap: 0;
        padding: 8px 18px 16px; background: rgba(8,9,11,.97); border-bottom: 1px solid var(--border);
        transform: translateY(-8px); opacity: 0; pointer-events: none; transition: opacity .2s, transform .2s;
      }
      .nav-links a { display: block; padding: 13px 0; font-size: 11px; color: var(--muted2); }
      .nav-toggle:checked ~ .nav-links { transform: translateY(0); opacity: 1; pointer-events: auto; }
      .nav-toggle:checked + .nav-menu-btn span { background: transparent; }
      .nav-toggle:checked + .nav-menu-btn span::before { background: var(--accent); transform: translateY(0) rotate(45deg); }
      .nav-toggle:checked + .nav-menu-btn span::after { background: var(--accent); transform: translateY(-2px) rotate(-45deg); }
      h1 { font-size: 2.25rem; }
      .hero-cover { margin-top: 28px; }
      .r-card { flex-direction: column; }
      .mode-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 420px) {
      h1 { font-size: 2.05rem; }
    }
  </style>
</head>
<body>

<nav>
  <a href="/" class="nav-logo">Alex <span>Anokhin</span></a>
  <input id="nav-toggle" class="nav-toggle" type="checkbox" aria-label="Toggle navigation" />
  <label class="nav-menu-btn" for="nav-toggle" aria-hidden="true"><span></span></label>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="/projects">Projects</a></li>
    <li><a href="/news">News</a></li>
  </ul>
</nav>

<div class="container">

  <!-- HERO -->
  <header class="hero">
    <p class="eyebrow">// olanokhin.com</p>
    <h1>Alex<br><span>Anokhin</span></h1>
    <p class="subtitle">
      Founding AI Engineer · Forward-Deployed AI<br>
      Production RAG · Agentic Systems · AI Security<br>
      Turning ambiguous business problems into adopted AI systems.
    </p>
    <div class="status">
      <span class="status-dot"></span>
      Currently @ Exyte · Heilbronn, Germany
    </div>

    <img
