      src="/img/social-media-card.jpg"
      alt="Alex Anokhin portrait with the slogan Building Intelligence. Expanding Humanity."
      width="1536"
      height="1024"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />

    <div class="contact-row">
      <a href="mailto:olanokhin@gmail.com" class="btn btn-primary">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        olanokhin@gmail.com
      </a>
      <a href="https://linkedin.com/in/olanokhin" target="_blank" rel="noopener" class="btn">
