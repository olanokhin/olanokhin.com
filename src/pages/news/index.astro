---
import { getCollection } from "astro:content";
import "../../styles/global.css";

const title = "News — Alex Anokhin";
const description = "AI and technology news through Alex Anokhin's personal technical filter.";
const canonical = "https://olanokhin.com/news";
const posts = (await getCollection("news", ({ data }) => data.status === "published"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Alex Anokhin" />
  <meta name="theme-color" content="#08090b" />
  <meta name="color-scheme" content="dark" />
  <meta name="format-detection" content="telephone=no" />
  <meta name="apple-mobile-web-app-title" content="Alex Anokhin" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="application/rss+xml" title="Alex Anokhin News RSS" href="https://olanokhin.com/rss.xml" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://olanokhin.com/img/social-media-card.jpg" />
  <meta property="og:image:width" content="1536" />
  <meta property="og:image:height" content="1024" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://olanokhin.com/img/social-media-card.jpg" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: canonical,
    hasPart: posts.map((post) => ({
      "@type": "NewsArticle",
      headline: post.data.title,
      url: `https://olanokhin.com/news/${post.data.slug ?? post.id}/`,
      datePublished: post.data.date.toISOString()
    }))
  })} />
  <link rel="icon" type="image/x-icon" href="/favicon_io/favicon.ico" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon_io/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon_io/favicon-32x32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon_io/apple-touch-icon.png" />
  <link rel="manifest" href="/favicon_io/site.webmanifest" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: 'JetBrains Mono', monospace; min-height: 100vh; }
    body::after { content: ''; position: fixed; inset: 0; z-index: 0; background-image: linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(90deg, var(--border) 1px, transparent 1px); background-size: 60px 60px; pointer-events: none; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 0 32px; height: 52px; display: flex; align-items: center; justify-content: space-between; background: rgba(8,9,11,.88); backdrop-filter: blur(14px); border-bottom: 1px solid var(--border); }
    .nav-logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 14px; color: #fff; text-decoration: none; }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 28px; list-style: none; }
    .nav-links a { font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); text-decoration: none; }
    .nav-links a:hover, .nav-links a[aria-current="page"] { color: var(--accent); }
    .nav-toggle { display: none; }
    .nav-menu-btn { display: none; width: 34px; height: 34px; border: 1px solid var(--border); border-radius: 6px; align-items: center; justify-content: center; cursor: pointer; background: var(--surface); }
    .nav-menu-btn span, .nav-menu-btn span::before, .nav-menu-btn span::after { display: block; width: 14px; height: 2px; border-radius: 2px; background: var(--text); content: ''; transition: transform .2s, opacity .2s, background .2s; }
    .nav-menu-btn span::before { transform: translateY(-5px); }
    .nav-menu-btn span::after { transform: translateY(3px); }
    main { position: relative; z-index: 1; max-width: 780px; margin: 0 auto; padding: 116px 24px 100px; }
    .eyebrow { font-size: 11px; letter-spacing: .2em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; }
    h1 { font-family: 'Syne', sans-serif; font-size: clamp(2.4rem, 6vw, 4rem); font-weight: 800; line-height: 1.05; color: #fff; }
    .subtitle { margin-top: 20px; font-size: 12px; color: var(--muted2); line-height: 1.9; max-width: 620px; }
    .feed-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 8px 13px; border: 1px solid rgba(var(--accent-rgb), .25); border-radius: 6px; color: var(--accent); background: var(--tag-bg); font-size: 11px; text-decoration: none; }
    .posts { display: grid; gap: 14px; margin-top: 48px; }
    .post { display: grid; grid-template-columns: 220px 1fr; gap: 18px; padding: 16px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface); text-decoration: none; color: inherit; transition: border-color .2s, background .2s; }
    .post:hover { border-color: rgba(var(--accent-rgb), .25); background: rgba(var(--accent-rgb), .03); }
    .cover { width: 100%; aspect-ratio: 16 / 10; object-fit: cover; border-radius: 6px; background: #050607; }
    .date { font-size: 10px; color: var(--accent); margin-bottom: 8px; letter-spacing: .08em; text-transform: uppercase; }
    .post-title { font-family: 'Syne', sans-serif; font-size: 18px; line-height: 1.2; font-weight: 700; color: #fff; margin-bottom: 10px; }
    .summary { font-size: 11px; color: var(--muted2); line-height: 1.75; }
    .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
    .tag { font-size: 10px; padding: 2px 8px; border-radius: 999px; border: 1px solid rgba(var(--accent-rgb), .2); color: var(--accent); background: var(--tag-bg); }
    footer { margin-top: 60px; padding-top: 32px; border-top: 1px solid var(--border); font-size: 11px; color: var(--muted); }
    @media (max-width: 700px) {
      h1 { font-size: 2.15rem; }
      .post { grid-template-columns: 1fr; }
      nav { padding: 0 18px; }
      .nav-menu-btn { display: flex; }
      .nav-links { position: absolute; top: 52px; left: 0; right: 0; display: grid; gap: 0; padding: 8px 18px 16px; background: rgba(8,9,11,.97); border-bottom: 1px solid var(--border); transform: translateY(-8px); opacity: 0; pointer-events: none; transition: opacity .2s, transform .2s; }
      .nav-links a { display: block; padding: 13px 0; font-size: 11px; color: var(--muted2); }
      .nav-toggle:checked ~ .nav-links { transform: translateY(0); opacity: 1; pointer-events: auto; }
      .nav-toggle:checked + .nav-menu-btn span { background: transparent; }
      .nav-toggle:checked + .nav-menu-btn span::before { background: var(--accent); transform: translateY(0) rotate(45deg); }
      .nav-toggle:checked + .nav-menu-btn span::after { background: var(--accent); transform: translateY(-2px) rotate(-45deg); }
    }
    @media (max-width: 420px) {
      h1 { font-size: 1.95rem; }
    }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-logo">Alex <span>Anokhin</span></a>
    <input id="nav-toggle" class="nav-toggle" type="checkbox" aria-label="Toggle navigation" />
    <label class="nav-menu-btn" for="nav-toggle" aria-hidden="true"><span></span></label>
    <ul class="nav-links">
      <li><a href="/">About</a></li>
      <li><a href="/projects">Projects</a></li>
      <li><a href="/news" aria-current="page">News</a></li>
    </ul>
  </nav>
  <main>
    <p class="eyebrow">// news</p>
    <h1>AI signal, filtered by hand</h1>
    <p class="subtitle">AI and technology updates that are worth attention, rewritten as signal rather than marketing noise.</p>
    <div class="feed-actions">
      <a class="btn" href="/rss.xml">RSS feed</a>
    </div>
    <section class="posts">
      {posts.map((post) => (
        <a class="post" href={`/news/${post.data.slug ?? post.id}/`}>
          {(post.data.thumbnail ?? post.data.image) && <img class="cover" src={post.data.thumbnail ?? post.data.image} alt={post.data.thumbnail_alt ?? post.data.image_alt ?? ""} loading="lazy" />}
          <div>
            <div class="date">{post.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</div>
            <div class="post-title">{post.data.title}</div>
            <div class="summary">{post.data.summary}</div>
            <div class="tags">{post.data.topics.map((topic) => <span class="tag">{topic}</span>)}</div>
          </div>
        </a>
      ))}
    </section>
    <footer>© 2026 Alex Anokhin</footer>
  </main>
</body>
</html>
