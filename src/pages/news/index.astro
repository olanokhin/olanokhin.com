---
const title = "News — Alex Anokhin";
const description = "AI and technology news through Alex Anokhin's personal technical filter.";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href="https://olanokhin.com/news" />
  <link rel="alternate" type="application/rss+xml" title="Alex Anokhin News RSS" href="/rss.xml" />
  <link rel="icon" type="image/x-icon" href="/favicon_io/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --bg:#08090b; --surface:#0f1114; --border:rgba(255,255,255,.07); --accent:#00e5c3; --text:#e8eaed; --muted:#5a6070; --muted2:#8892a0; }
    body { background: var(--bg); color: var(--text); font-family: 'JetBrains Mono', monospace; min-height: 100vh; }
    body::after { content: ''; position: fixed; inset: 0; z-index: 0; background-image: linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(90deg, var(--border) 1px, transparent 1px); background-size: 60px 60px; pointer-events: none; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 0 32px; height: 52px; display: flex; align-items: center; justify-content: space-between; background: rgba(8,9,11,.88); backdrop-filter: blur(14px); border-bottom: 1px solid var(--border); }
    .nav-logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 14px; color: #fff; text-decoration: none; }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 28px; list-style: none; }
    .nav-links a { font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); text-decoration: none; }
    .nav-links a:hover, .nav-links a[aria-current="page"] { color: var(--accent); }
    main { position: relative; z-index: 1; max-width: 780px; margin: 0 auto; padding: 116px 24px 100px; }
    .eyebrow { font-size: 11px; letter-spacing: .2em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; }
    h1 { font-family: 'Syne', sans-serif; font-size: clamp(2.4rem, 6vw, 4rem); font-weight: 800; line-height: 1.05; color: #fff; }
    .subtitle { margin-top: 20px; font-size: 12px; color: var(--muted2); line-height: 1.9; max-width: 620px; }
    .empty { margin-top: 48px; padding: 24px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface); }
    .empty-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; color: #fff; margin-bottom: 8px; }
    .empty-text { font-size: 11px; color: var(--muted2); line-height: 1.75; }
    footer { margin-top: 60px; padding-top: 32px; border-top: 1px solid var(--border); font-size: 11px; color: var(--muted); }
    @media (max-width: 600px) { .nav-links { display: none; } }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-logo">Alex <span>Anokhin</span></a>
    <ul class="nav-links">
      <li><a href="/">About</a></li>
      <li><a href="/projects">Projects</a></li>
      <li><a href="/news" aria-current="page">News</a></li>
    </ul>
  </nav>
  <main>
    <p class="eyebrow">// news</p>
    <h1>AI signal, filtered by hand</h1>
    <p class="subtitle">A future RSS-backed news stream for AI and technology updates that are actually worth attention.</p>
    <section class="empty">
      <div class="empty-title">No published notes yet</div>
      <div class="empty-text">This section is ready for the Telegram/n8n approval flow. Approved drafts will become Markdown/MDX posts in the repository, then Vercel will publish them automatically.</div>
    </section>
    <footer>© 2026 Alex Anokhin</footer>
  </main>
</body>
</html>
